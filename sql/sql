CREATE DATABASE internship_management_system;
USE internship_management_system;

-- Table: faculty
CREATE TABLE faculty (
    faculty_id INT AUTO_INCREMENT PRIMARY KEY,
    faculty_name VARCHAR(100) NOT NULL
);

-- Table: major
CREATE TABLE major (
    major_id INT AUTO_INCREMENT PRIMARY KEY,
    major_name VARCHAR(100) NOT NULL,
    faculty_id INT,
    FOREIGN KEY (faculty_id) REFERENCES faculty(faculty_id)
);

-- Table: department
CREATE TABLE department (
    department_id INT AUTO_INCREMENT PRIMARY KEY,
    department_name VARCHAR(100) NOT NULL,
    faculty_id INT,
    FOREIGN KEY (faculty_id) REFERENCES faculty(faculty_id)
);

-- Table: student
CREATE TABLE student (
    student_id INT AUTO_INCREMENT PRIMARY KEY,
    student_code VARCHAR(20) UNIQUE NOT NULL,
    full_name VARCHAR(100) NOT NULL,
    email VARCHAR(100),
    phone VARCHAR(20),
    birth_date DATE,
    faculty_id INT,
    major_id INT,
    internship_status ENUM('searching','interning','completed','cancelled'),
    FOREIGN KEY (faculty_id) REFERENCES faculty(faculty_id),
    FOREIGN KEY (major_id) REFERENCES major(major_id)
);

-- Table: lecturer
CREATE TABLE lecturer (
    lecturer_id INT AUTO_INCREMENT PRIMARY KEY,
    lecturer_code VARCHAR(20) UNIQUE NOT NULL,
    full_name VARCHAR(100) NOT NULL,
    email VARCHAR(100),
    department_id INT,
    role ENUM('advisor','internship_supervisor'),
    FOREIGN KEY (department_id) REFERENCES department(department_id)
);

-- Table: company
CREATE TABLE company (
    company_id INT AUTO_INCREMENT PRIMARY KEY,
    company_name VARCHAR(150) NOT NULL,
    address VARCHAR(200),
    industry VARCHAR(100),
    website VARCHAR(100)
);

-- Table: hr
CREATE TABLE hr (
    hr_id INT AUTO_INCREMENT PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    email VARCHAR(100),
    company_id INT,
    FOREIGN KEY (company_id) REFERENCES company(company_id)
);

-- Table: mentor
CREATE TABLE mentor (
    mentor_id INT AUTO_INCREMENT PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    email VARCHAR(100),
    company_id INT,
    expertise VARCHAR(100),
    FOREIGN KEY (company_id) REFERENCES company(company_id)
);

-- Table: internship_batch
CREATE TABLE internship_batch (
    batch_id INT AUTO_INCREMENT PRIMARY KEY,
    batch_name VARCHAR(100) NOT NULL,
    start_date DATE,
    end_date DATE,
    description TEXT
);

-- Table: internship_assignment
CREATE TABLE internship_assignment (
    assignment_id INT AUTO_INCREMENT PRIMARY KEY,
    student_id INT,
    company_id INT,
    mentor_id INT,
    hr_id INT,
    lecturer_id INT,
    batch_id INT,
    status ENUM('searching','interning','completed','cancelled'),
    FOREIGN KEY (student_id) REFERENCES student(student_id),
    FOREIGN KEY (company_id) REFERENCES company(company_id),
    FOREIGN KEY (mentor_id) REFERENCES mentor(mentor_id),
    FOREIGN KEY (hr_id) REFERENCES hr(hr_id),
    FOREIGN KEY (lecturer_id) REFERENCES lecturer(lecturer_id),
    FOREIGN KEY (batch_id) REFERENCES internship_batch(batch_id)
);

-- Table: internship_report
CREATE TABLE internship_report (
    report_id INT AUTO_INCREMENT PRIMARY KEY,
    assignment_id INT,
    submission_date DATE,
    report_file VARCHAR(200),
    summary TEXT,
    FOREIGN KEY (assignment_id) REFERENCES internship_assignment(assignment_id)
);

-- Table: evaluation
CREATE TABLE evaluation (
    evaluation_id INT AUTO_INCREMENT PRIMARY KEY,
    report_id INT,
    evaluator_id INT,
    evaluator_role ENUM('lecturer','mentor'),
    score DECIMAL(4,2),
    feedback TEXT,
    FOREIGN KEY (report_id) REFERENCES internship_report(report_id)
);

-- Table: internship_contract
CREATE TABLE internship_contract (
    contract_id INT AUTO_INCREMENT PRIMARY KEY,
    assignment_id INT,
    signed_date DATE,
    end_date DATE,
    terms TEXT,
    FOREIGN KEY (assignment_id) REFERENCES internship_assignment(assignment_id)
);

